# Slack Daily Digest Bot — Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# For Standalone Daily Digest (summarizer.py)
# ============================================================================
# Your personal Slack user token (get from api.slack.com/apps → OAuth & Permissions)
SLACK_USER_TOKEN=xoxp-your-user-token-here

# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Channel where daily summaries will be posted
SUMMARY_CHANNEL=yourname-daily-summary


# ============================================================================
# For Multi-User Bot Server (bot.py)
# ============================================================================
# Bot token for posting messages (get from api.slack.com/apps → OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing secret for verifying webhook requests (get from api.slack.com/apps → Basic Information)
SLACK_SIGNING_SECRET=your-signing-secret-here

# OAuth client credentials (get from api.slack.com/apps → Basic Information)
SLACK_CLIENT_ID=5596012676549.10799568727585
SLACK_CLIENT_SECRET=your-client-secret-here

# Public URL where bot is accessible (update with your ngrok URL)
BASE_URL=https://your-ngrok-url.ngrok-free.dev


# ============================================================================
# Notes
# ============================================================================
# - SLACK_USER_TOKEN is only needed for standalone mode (summarizer.py)
# - Bot server (bot.py) stores user tokens in users.db after OAuth
# - BASE_URL must match the redirect URL registered in Slack app settings
# - After restarting ngrok, update BASE_URL and Slack app redirect URL
